function Controller() {
    // Constructor
}

Controller.prototype.IntroductionPageCallback = function() {
    // Forcefully disable/hide the Settings button on the introduction page
    gui.setSettingsButtonEnabled(false);
    
    var wizard = gui.wizard();
    if (wizard) {
        var settingsButton = gui.findChild(wizard, "SettingsButton");
        if (settingsButton) {
            settingsButton.visible = false;
        }
        var settingsButtonLower = gui.findChild(wizard, "settingsButton");
        if (settingsButtonLower) {
            settingsButtonLower.visible = false;
        }
    }
}
