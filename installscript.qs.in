function Component() {
    // IFW keeps the product version from the original offline installer unless
    // an updated core component refreshes it before the maintenance tool is
    // rewritten. Windows uses this value for Apps & Features DisplayVersion.
    if (systemInfo.productType === "windows")
        installer.setValue("ProductVersion", "@CPACK_PACKAGE_VERSION@");
}

Component.prototype.createOperations = function() {
    // Call default implementation to extract files first
    component.createOperations();

    if (systemInfo.productType === "windows") {
        var updateDisplayVersionScript =
            "$target = [System.IO.Path]::GetFullPath('@DEPLOYKIT_IFW_TARGET_DIR@').TrimEnd('\\\\'); " +
            "$roots = @(" +
            "'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall'," +
            "'HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall'," +
            "'HKLM:\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall'); " +
            "foreach ($root in $roots) { " +
            "if (-not (Test-Path $root)) { continue } " +
            "foreach ($key in Get-ChildItem $root) { " +
            "$entry = Get-ItemProperty $key.PSPath -ErrorAction SilentlyContinue; " +
            "if ($entry.DisplayName -ne '@DEPLOYKIT_TARGET_NAME@' -or -not $entry.InstallLocation) { continue } " +
            "try { $location = [System.IO.Path]::GetFullPath([string]$entry.InstallLocation).TrimEnd('\\\\') } catch { continue } " +
            "if ($location -ieq $target) { Set-ItemProperty -Path $key.PSPath -Name DisplayVersion -Value '@CPACK_PACKAGE_VERSION@' } " +
            "} }";
        component.addOperation("Execute",
                               "powershell.exe",
                               "-NoProfile",
                               "-ExecutionPolicy",
                               "Bypass",
                               "-Command",
                               updateDisplayVersionScript);

        // Start Menu Shortcut
        component.addOperation("CreateShortcut",
                               "@DEPLOYKIT_IFW_TARGET_DIR@/@DEPLOYKIT_TARGET_EXE@",
                               "@DEPLOYKIT_IFW_START_MENU_DIR@/@DEPLOYKIT_TARGET_NAME@.lnk",
                               "workingDirectory=@DEPLOYKIT_IFW_TARGET_DIR@",
                               "iconPath=@DEPLOYKIT_IFW_TARGET_DIR@/@DEPLOYKIT_TARGET_EXE@");

        // Desktop Shortcut
        if ("@DEPLOYKIT_CREATE_DESKTOP_LINKS@" !== "") {
            component.addOperation("CreateShortcut",
                                   "@DEPLOYKIT_IFW_TARGET_DIR@/@DEPLOYKIT_TARGET_EXE@",
                                   "@DEPLOYKIT_IFW_DESKTOP_DIR@/@DEPLOYKIT_TARGET_NAME@.lnk",
                                   "workingDirectory=@DEPLOYKIT_IFW_TARGET_DIR@",
                                   "iconPath=@DEPLOYKIT_IFW_TARGET_DIR@/@DEPLOYKIT_TARGET_EXE@");
        }
    }
}
